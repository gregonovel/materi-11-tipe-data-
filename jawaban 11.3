def baca_file(nama_file):
    try:
        with open(nama_file, 'r', encoding='utf-8') as file:
            return file.read()
    except:
        print(f"File '{nama_file}' tidak ditemukan.")
        return None

def cari_kata_dengan_karakter_unik(teks):
    karakter_unik = set("$@#&*()^%~`[]{};:!?,.+-=/\\|<>0123456789")
    
    kata_kata = teks.split()
    hasil = []
    
    for kata in kata_kata:
        for char in kata:
            if char in karakter_unik:
                hasil.append(kata)
                break
    
    return hasil

nama_file = input("Masukkan nama file: ")

teks = baca_file(nama_file)

if teks:
    hasil = cari_kata_dengan_karakter_unik(teks)
    
    print(f"\nKata yang mengandung karakter unik:")
    print(f"Jumlah: {len(hasil)}")
    
    for i, kata in enumerate(hasil, 1):
        print(f"{i:3}. {kata}")
